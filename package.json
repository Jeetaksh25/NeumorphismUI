{
  "name": "@jeetaksh/neumorphism-ui",
  "version": "1.0.2",
  "description": "A premium neumorphism React component library with 60+ themes, built for Next.js and modern React apps.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "neumorphism",
    "react",
    "ui",
    "components",
    "design-system",
    "tailwindcss",
    "nextjs",
    "theme"
  ],
  "author": "Jeetaksh <https://github.com/Jeetaksh25>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeetaksh25/NeumorphismUI.git"
  },
  "bugs": {
    "url": "https://github.com/Jeetaksh25/NeumorphismUI/issues"
  },
  "homepage": "https://github.com/Jeetaksh25/NeumorphismUI#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
